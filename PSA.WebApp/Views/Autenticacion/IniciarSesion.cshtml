@model PSA.EntidadesDTO.DTOs.InicioSesionDTO

@{
    Layout = "~/Views/Shared/_LayoutAutenticacion.cshtml";
    ViewData["Title"] = "Iniciar sesión";
}
<div class="tarjeta-autenticacion">
    @if (TempData["MensajeExito"] is string mensajeExito && !string.IsNullOrWhiteSpace(mensajeExito))
    {
        <div class="alert alert-success" role="status" data-auto-dismiss-ms="8000">
            @mensajeExito
        </div>
    }

    <div class="cabecera-formulario">
        <span class="eyebrow">Acceso seguro</span>
        <h2>Bienvenido</h2>
        <p>Ingrese su correo y contraseña para continuar.</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <form class="formulario-base" id="formularioIniciarSesion" novalidate method="post" asp-controller="Autenticacion" asp-action="IniciarSesion">
        @Html.AntiForgeryToken()
        <div class="campo-formulario">
            <label asp-for="Email">Correo electrónico</label>
            <input asp-for="Email" type="email" placeholder="usuario@correo.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
            <small class="texto-ayuda">Use el correo registrado en el sistema.</small>
        </div>

        <div class="campo-formulario">
            <div class="fila-entre-extremos">
                <label asp-for="Contrasena">Contraseña</label>
                <a asp-controller="Autenticacion" asp-action="RecuperarContrasena">¿La olvidó?</a>
            </div>
            <input asp-for="Contrasena" type="password" placeholder="Ingrese su contraseña" />
            <span asp-validation-for="Contrasena" class="text-danger"></span>
        </div>

        <div class="fila-acciones-formulario">
            <button type="submit" class="boton-primario boton-bloque">Iniciar sesión</button>
        </div>
    </form>

    <div class="pie-formulario">
        <p>
            ¿Aún no tiene cuenta?
            <a asp-controller="Autenticacion" asp-action="RegistroUsuario">Registrarse</a>
        </p>
    </div>

    <div class="lista-accesos">
        <a class="acceso-rapido" asp-controller="Dashboard" asp-action="Dueno">Entrar como dueño</a>
        <a class="acceso-rapido" asp-controller="Dashboard" asp-action="Ingeniero">Entrar como ingeniero</a>
        <a class="acceso-rapido" asp-controller="Dashboard" asp-action="Administrador">Entrar como administrador</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
