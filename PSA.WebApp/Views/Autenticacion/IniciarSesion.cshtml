@{
    Layout = "~/Views/Shared/_LayoutAutenticacion.cshtml";
    ViewData["Title"] = "Iniciar sesión";
}
<div class="tarjeta-autenticacion">
    <div class="cabecera-formulario">
        <span class="eyebrow">Acceso seguro</span>
        <h2>Bienvenido</h2>
        <p>Ingrese su correo y contraseña para continuar.</p>
    </div>

    <form class="formulario-base" id="formularioIniciarSesion" novalidate>
        <div class="campo-formulario">
            <label for="correo">Correo electrónico</label>
            <input id="correo" name="correo" type="email" placeholder="usuario@correo.com" />
            <small class="texto-ayuda">Use el correo registrado en el sistema.</small>
        </div>

        <div class="campo-formulario">
            <div class="fila-entre-extremos">
                <label for="contrasena">Contraseña</label>
                <a asp-controller="Autenticacion" asp-action="RecuperarContrasena">¿La olvidó?</a>
            </div>
            <input id="contrasena" name="contrasena" type="password" placeholder="Ingrese su contraseña" />
        </div>

        <div class="fila-acciones-formulario">
            <button type="submit" class="boton-primario boton-bloque">Iniciar sesión</button>
        </div>
    </form>

    <div class="pie-formulario">
        <p>
            ¿Aún no tiene cuenta?
            <a asp-controller="Autenticacion" asp-action="RegistroUsuario">Registrarse</a>
        </p>
    </div>
</div>
