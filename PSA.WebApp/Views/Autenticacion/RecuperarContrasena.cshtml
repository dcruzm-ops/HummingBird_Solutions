@{
    Layout = "~/Views/Shared/_LayoutAutenticacion.cshtml";
    ViewData["Title"] = "Recuperar contraseña";
}
<div class="tarjeta-autenticacion">
    <div class="cabecera-formulario">
        <span class="eyebrow">Soporte de acceso</span>
        <h2>Recuperar contraseña</h2>
        <p>Le enviaremos un enlace o token para restablecer su acceso.</p>
    </div>

    <form class="formulario-base" id="formularioRecuperarContrasena" novalidate>
        <div class="campo-formulario">
            <label for="correoRecuperacion">Correo electrónico</label>
            <input id="correoRecuperacion" name="correoRecuperacion" type="email" placeholder="usuario@correo.com" />
        </div>

        <div class="fila-acciones-formulario">
            <button type="submit" class="boton-primario boton-bloque">Enviar instrucciones</button>
        </div>
    </form>

    <div class="pie-formulario">
        <p>
            ¿Recordó su contraseña?
            <a asp-controller="Autenticacion" asp-action="IniciarSesion">Volver al inicio de sesión</a>
        </p>
    </div>
</div>
