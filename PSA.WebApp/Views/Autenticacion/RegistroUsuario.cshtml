@{
    Layout = "~/Views/Shared/_LayoutAutenticacion.cshtml";
    ViewData["Title"] = "Registro de usuario";
}
<div class="tarjeta-autenticacion">
    <div class="cabecera-formulario">
        <span class="eyebrow">Nuevo acceso</span>
        <h2>Crear cuenta</h2>
        <p>Registre un usuario base para el rol de dueño de finca.</p>
    </div>

    <form class="formulario-base" id="formularioRegistroUsuario" novalidate>
        <div class="grid-dos-columnas">
            <div class="campo-formulario">
                <label for="nombre">Nombre</label>
                <input id="nombre" name="nombre" type="text" placeholder="Nombre" />
            </div>
            <div class="campo-formulario">
                <label for="apellido">Apellido</label>
                <input id="apellido" name="apellido" type="text" placeholder="Apellido" />
            </div>
        </div>

        <div class="campo-formulario">
            <label for="correoRegistro">Correo electrónico</label>
            <input id="correoRegistro" name="correoRegistro" type="email" placeholder="usuario@correo.com" />
        </div>

        <div class="campo-formulario">
            <label for="telefono">Teléfono</label>
            <input id="telefono" name="telefono" type="tel" placeholder="8888-8888" />
        </div>

        <div class="grid-dos-columnas">
            <div class="campo-formulario">
                <label for="contrasenaRegistro">Contraseña</label>
                <input id="contrasenaRegistro" name="contrasenaRegistro" type="password" placeholder="Mínimo 8 caracteres" />
            </div>
            <div class="campo-formulario">
                <label for="confirmarContrasena">Confirmar contraseña</label>
                <input id="confirmarContrasena" name="confirmarContrasena" type="password" placeholder="Repita la contraseña" />
            </div>
        </div>

        <div class="campo-formulario">
            <label for="rolRegistro">Rol inicial</label>
            <select id="rolRegistro" name="rolRegistro">
                <option value="Dueno">Dueño de finca</option>
                <option value="Ingeniero">Ingeniero forestal</option>
                <option value="Administrador">Administrador</option>
            </select>
        </div>

        <label class="control-check">
            <input type="checkbox" id="terminos" name="terminos" />
            <span>Acepto las condiciones base de uso del sistema.</span>
        </label>

        <div class="fila-acciones-formulario">
            <button type="submit" class="boton-primario boton-bloque">Registrar usuario</button>
        </div>
    </form>

    <div class="pie-formulario">
        <p>
            ¿Ya tiene cuenta?
            <a asp-controller="Autenticacion" asp-action="IniciarSesion">Iniciar sesión</a>
        </p>
    </div>
</div>
