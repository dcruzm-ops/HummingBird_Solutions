@model PSA.EntidadesDTO.DTOs.RegistrarUsuarioDTO

@{
    Layout = "~/Views/Shared/_LayoutAutenticacion.cshtml";
    ViewData["Title"] = "Registro de usuario";
}

<section class="contenedor-autenticacion">
    <div class="tarjeta-autenticacion">
        <h1>Registro de usuario</h1>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <form asp-controller="Autenticacion" asp-action="RegistroUsuario" method="post">
            <div class="campo-formulario">
                <label asp-for="NombreCompleto"></label>
                <input asp-for="NombreCompleto" class="form-control" />
                <span asp-validation-for="NombreCompleto" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="Contrasena"></label>
                <input asp-for="Contrasena" type="password" class="form-control" />
                <span asp-validation-for="Contrasena" class="text-danger"></span>
            </div>

            <div class="campo-formulario">
                <label asp-for="ConfirmacionContrasena"></label>
                <input asp-for="ConfirmacionContrasena" type="password" class="form-control" />
                <span asp-validation-for="ConfirmacionContrasena" class="text-danger"></span>
            </div>

            <p class="texto-ayuda">Las cuentas nuevas se crean con rol <strong>Propietario</strong> por defecto.</p>

            <button type="submit" class="boton-primario">Registrarse</button>
        </form>

        <p class="mt-3">
            ¿Ya tiene cuenta?
            <a asp-controller="Autenticacion" asp-action="IniciarSesion">Iniciar sesión</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
