@{
    var titulo = ViewBag.TituloPagina as string ?? ViewData["Title"]?.ToString() ?? "PSA Costa Rica";
    var rolActivo = ViewBag.RolActivo as string ?? "Dueno";
}
<!DOCTYPE html>
<html lang="es" data-tema="claro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@titulo - PSA Costa Rica</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/componentes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/propietario.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ingeniero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/administrador.css" asp-append-version="true" />
</head>
<body class="aplicacion-shell">
    @await Html.PartialAsync("_Encabezado")
    <div class="contenedor-aplicacion">
        @await Html.PartialAsync("_BarraLateral")
        <main class="contenido-principal" role="main">
            @await Html.PartialAsync("_MigasPan")
            @await Html.PartialAsync("_MensajesSistema")
            @RenderBody()
        </main>
    </div>
    @await Html.PartialAsync("_PiePagina")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/utilidades.js" asp-append-version="true"></script>
    <script src="~/js/navegacion.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
