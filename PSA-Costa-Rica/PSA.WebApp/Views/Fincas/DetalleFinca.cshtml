@model PSA.WebApp.Models.Fincas.FincaViewModel

@{
    ViewData["Title"] = "Detalle de finca";

    var ubicacion = $"{Model.Provincia}, {Model.Canton}, {Model.Distrito}";
    var recursosHidricos = Model.TieneRecursosHidricos ? "Sí" : "No";
    var direccionExacta = string.IsNullOrWhiteSpace(Model.DireccionExacta) ? "No registrada" : Model.DireccionExacta;
    var fechaActualizacion = Model.FechaActualizacion == DateTime.MinValue
        ? "No disponible"
        : Model.FechaActualizacion.ToString("dd/MM/yyyy");
    var fechaRegistro = Model.FechaRegistro == DateTime.MinValue
        ? "No disponible"
        : Model.FechaRegistro.ToString("dd/MM/yyyy");
}

<section class="seccion-pagina propietario-detalle-finca">
    <div class="cabecera-pagina">
        <div>
            <span class="eyebrow">Finca #@Model.IdFinca</span>
            <h2>@Model.NombreFinca</h2>
            <p>Vista tipo detalle para el módulo del dueño.</p>
        </div>
        <div class="grupo-acciones">
            <button type="button" class="boton-secundario">Actualizar cuenta bancaria</button>
            <button type="button" class="boton-primario">Adjuntar evidencia</button>
        </div>
    </div>

    <div class="grid-tarjetas-kpi">
        <article class="tarjeta-kpi">
            <span class="etiqueta-kpi">Estado de finca</span>
            <strong>@Model.EstadoFinca</strong>
            <small>Estado actual registrado en el sistema.</small>
        </article>
        <article class="tarjeta-kpi">
            <span class="etiqueta-kpi">Uso de suelo</span>
            <strong>@Model.UsoSuelo</strong>
            <small>Clasificación actual del terreno.</small>
        </article>
        <article class="tarjeta-kpi">
            <span class="etiqueta-kpi">Recursos hídricos</span>
            <strong>@recursosHidricos</strong>
            <small>Disponibilidad registrada para la finca.</small>
        </article>
    </div>

    <div class="grid-dos-paneles">
        <section class="tarjeta-panel">
            <div class="cabecera-bloque">
                <h3>Datos generales</h3>
            </div>
            <dl class="lista-detalle">
                <div><dt>ID de finca</dt><dd>@Model.IdFinca</dd></div>
                <div><dt>ID propietario</dt><dd>@Model.IdPropietario</dd></div>
                <div><dt>Nombre</dt><dd>@Model.NombreFinca</dd></div>
                <div><dt>Ubicación</dt><dd>@ubicacion</dd></div>
                <div><dt>Dirección exacta</dt><dd>@direccionExacta</dd></div>
                <div><dt>Hectáreas</dt><dd>@Model.Hectareas</dd></div>
            </dl>
        </section>

        <section class="tarjeta-panel">
            <div class="cabecera-bloque">
                <h3>Características</h3>
            </div>
            <ul class="lista-timeline">
                <li>Vegetación: @Model.Vegetacion.</li>
                <li>Uso de suelo: @Model.UsoSuelo.</li>
                <li>Pendiente: @Model.Pendiente.</li>
                <li>Latitud: @Model.Latitud.</li>
                <li>Longitud: @Model.Longitud.</li>
                <li>Última actualización: @fechaActualizacion.</li>
            </ul>
        </section>
    </div>

    <div class="grid-dos-paneles">
        <section class="tarjeta-panel">
            <div class="cabecera-bloque">
                <h3>Información adicional</h3>
            </div>
            <div class="estado-vacio-inline">
                <p><strong>Fecha de registro:</strong> @fechaRegistro</p>
                <p><strong>Fecha de actualización:</strong> @fechaActualizacion</p>
            </div>
        </section>

        <section class="tarjeta-panel">
            <div class="cabecera-bloque">
                <h3>Historial de pagos</h3>
            </div>
            <div class="estado-vacio-inline">
                <p>La finca aún no cuenta con plan de pago asociado.</p>
            </div>
        </section>
    </div>
</section>